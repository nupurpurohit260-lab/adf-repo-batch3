					{
						"name": "S3DataTransformationS3",
						"type": "ExecuteDataFlow",
						"dependsOn": [
							{
								"activity": "CopyFileFromS3",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
