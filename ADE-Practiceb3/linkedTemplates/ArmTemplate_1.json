	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/5_PL_External_S3_File_Transfer')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "CopyFileFromS3",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
