{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ADE-Practiceb3"
		},
		"LS_AWS_S3_secretAccessKey": {
			"type": "secureString",
			"metadata": "Secure string for 'secretAccessKey' of 'LS_AWS_S3'"
		},
		"LS_DL_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_DL'"
		},
		"LS_AWS_S3_properties_typeProperties_accessKeyId": {
			"type": "string",
			"defaultValue": "AKIAZMHETFYSUEZGVLFA"
		},
		"LS_DL_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://b3datalake15thmay.dfs.core.windows.net/"
		},
		"TG_PRODReady_Event_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/a06437b2-7d47-4ec2-a9cb-1ca084e70df7/resourceGroups/ADE-Practice_B3/providers/Microsoft.Storage/storageAccounts/b3datalake15thmay"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ADE-Practiceb3_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AWS_S3_secretAccessKey": {
						"value": "[parameters('LS_AWS_S3_secretAccessKey')]"
					},
					"LS_DL_accountKey": {
						"value": "[parameters('LS_DL_accountKey')]"
					},
					"LS_AWS_S3_properties_typeProperties_accessKeyId": {
						"value": "[parameters('LS_AWS_S3_properties_typeProperties_accessKeyId')]"
					},
					"LS_DL_properties_typeProperties_url": {
						"value": "[parameters('LS_DL_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "ADE-Practiceb3_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"TG_PRODReady_Event_properties_typeProperties_scope": {
						"value": "[parameters('TG_PRODReady_Event_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'ADE-Practiceb3_ArmTemplate_0')]"
			]
		}
	]
}